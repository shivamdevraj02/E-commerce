<header class="bg-gray-900 text-white">
    <nav class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
        
        <h1 class="text-2xl font-bold text-green-400">
            E-Commerce
        </h1>

        <ul class="flex gap-6">
            <li>
                <a href="/" class="hover:text-green-400 transition">
                    Home
                </a>
            </li>


            <% if(isLoggedIn) { %>

            <li>
                <a href="/products" class="hover:text-green-400 transition">
                    Products
                </a>
            </li>

            <li>
                <a href="/orders" class="hover:text-green-400 transition">
                    Orders
                </a>
            </li>

            <li>
                <a href="/cart" class="hover:text-green-400 transition">
                    Cart
                </a>
            </li>

            <% } %>

            

            <% if(!isLoggedIn) { %>


                 <li>
                <a href="/signup" class="hover:text-green-400 transition">
                    Signup
                </a>
            </li>


            <li>
                <a href="/login" class="hover:text-green-400 transition">
                    Login
                </a>
            </li>

            <% } else { %>

                <form method="POST" action="/logout">
    <button type="submit" class="hover:text-green-400 transition">
        Logout
    </button>
</form>
            <% } %>
        </ul>

    </nav>
</header>