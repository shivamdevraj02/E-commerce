                    </div>
                </div>

                <div class="product-card">
                    <img src="https://plus.unsplash.com/premium_photo-1725075085043-79932bdbcde6?w=600&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MXx8d2lyZWxlc3MlMjBrZXlib2FyZHxlbnwwfHwwfHx8MA%3D%3D" alt="Wireless Keyboard">
