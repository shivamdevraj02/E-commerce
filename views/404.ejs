<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404 - Page Not Found</title>

    <style>
        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body{
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #f4f4f4;
        }

        .container{
            text-align: center;
        }

        h1{
            font-size: 120px;
            color: #667eea;
        }

        h2{
            margin-bottom: 15px;
            color: #333;
        }

        p{
            color: #666;
            margin-bottom: 20px;
        }

        a{
            display: inline-block;
            text-decoration: none;
            background: #667eea;
            color: white;
            padding: 12px 25px;
            border-radius: 8px;
        }

        a:hover{
            background: #5563d6;
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>404</h1>
        <h2>Page Not Found</h2>
        <p>Sorry, the page you are looking for does not exist.</p>

        <a href="/">Go Back Home</a>
    </div>

</body>
</html>